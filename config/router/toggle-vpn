#!/bin/sh
# toggle-vpn - Hubert's VPN Control v3.6

IFACE_PROTON="PROTON"
IFACE_WARP="WARP"
CONF="/root/.vpn_provider"
IP="/sbin/ip"
NFT="/usr/sbin/nft"
UBUS="/sbin/ubus"

MARK=0x1
TABLE=200
LAN_NET="192.168.1.0/24"
LAN_HOST="192.168.1.49"

[ ! -s "$CONF" ] && echo "PROTON" > "$CONF"
PROV=$(cat "$CONF" | tr '[:lower:]' '[:upper:]' | xargs)

get_device() {
    local iface=""
    [ "$PROV" = "PROTON" ] && iface="$IFACE_PROTON" || iface="$IFACE_WARP"
    local dev=$($IP addr show "$iface" 2>/dev/null | grep -oE '^[0-9]+: [^:]+' | cut -d' ' -f2 | tr -d '@')
    [ -z "$dev" ] && dev=$($UBUS call network.interface."$iface" status 2>/dev/null | grep '"l3_device":' | cut -d'"' -f4)
    echo "$dev"
}

clean_rules() {
    for prio in 40 45 50; do
        while $IP rule del priority $prio 2>/dev/null; do :; done
    done
    $IP route flush table $TABLE 2>/dev/null
    $NFT delete rule inet fw4 mangle_prerouting ip daddr @vpn_selective counter meta mark set $MARK 2>/dev/null
    $NFT delete rule inet fw4 forward tcp flags syn tcp option maxseg size set rt mtu 2>/dev/null
}

case "$1" in
    on|start|selective_on)
        clean_rules
        [ "$PROV" = "PROTON" ] && logic_if="$IFACE_PROTON" || logic_if="$IFACE_WARP"

        /sbin/ifup "$logic_if"
        DEV=""
        for i in $(seq 1 15); do
            sleep 1
            DEV=$(get_device)
            [ -n "$DEV" ] && break
            printf "."
        done
        echo ""

        if [ -z "$DEV" ]; then
            echo "BŁĄD: $logic_if nie wstał. Sprawdź logread | grep WireGuard"
            exit 1
        fi

        $IP route replace default dev "$DEV" table $TABLE 2>/dev/null
        $NFT add rule inet fw4 forward oifname "$DEV" tcp flags syn tcp option maxseg size set rt mtu 2>/dev/null

        if [ "$1" = "selective_on" ]; then
            /root/vpn-refresh-domains
            $NFT add rule inet fw4 mangle_prerouting ip daddr @vpn_selective counter meta mark set $MARK
            $IP rule add fwmark $MARK lookup $TABLE priority 45
        else
            $IP rule add to $LAN_NET lookup main priority 40
            $IP rule add from $LAN_NET lookup $TABLE priority 50
        fi

        echo 2 > /proc/sys/net/ipv4/conf/all/rp_filter
        [ -d "/proc/sys/net/ipv4/conf/$DEV" ] && echo 2 > "/proc/sys/net/ipv4/conf/$DEV/rp_filter"
        # --quick: tylko lokalny status, bez SSH na .49 i bez api.ipify.org
        $0 status --quick ;;

    off|stop|selective_off)
        clean_rules
        /sbin/ifdown "$IFACE_PROTON" 2>/dev/null
        /sbin/ifdown "$IFACE_WARP" 2>/dev/null
        echo 1 > /proc/sys/net/ipv4/conf/all/rp_filter
        # --quick: tylko lokalny status, bez SSH na .49 i bez api.ipify.org
        $0 status --quick ;;

    status)
        DEV=$(get_device)
        MODE="INACTIVE"
        $IP rule show | grep -q "50:" && MODE="GLOBAL"
        $IP rule show | grep -q "45:" && MODE="SELECTIVE"

        WAN=$($IP route get 1.1.1.1 2>/dev/null | grep -oE 'src [0-9.]+' | awk '{print $2}')
        [ -z "$WAN" ] && WAN=$(wget -qO- http://ipinfo.io/ip --timeout=2 2>/dev/null || echo "Błąd")

        [ -z "$DEV" ] && S_NAME="$PROV (OFF)" || S_NAME="$PROV ($DEV)"

        if [ "$2" = "--quick" ]; then
            # Wywołanie automatyczne (z on/off) - bez SSH, bez api.ipify.org
            printf "VPN: %s | MODE: %s | WAN: %s\n" "$S_NAME" "$MODE" "$WAN"
        else
            # Wywołanie manualne - pełny status z IP hosta .49
            VPN_49=$(ssh -o BatchMode=yes root@$LAN_HOST "wget -qO- http://api.ipify.org --timeout=2" 2>/dev/null || echo "Timeout")
            printf "VPN: %s | MODE: %s | WAN: %s | VPN (.49): %s\n" "$S_NAME" "$MODE" "$WAN" "$VPN_49"
        fi ;;
esac
