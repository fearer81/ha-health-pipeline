#!/bin/sh
LIST="/root/vpn-domains.list"
SET_NAME="vpn_selective"
FW_PATH="4#inet#fw4#$SET_NAME"

[ ! -f "$LIST" ] && exit 1

# Wymuszenie istnienia zestawu w firewallu
nft add set inet fw4 $SET_NAME "{ type ipv4_addr; flags interval; }" 2>/dev/null
nft flush set inet fw4 $SET_NAME

uci set dhcp.@dnsmasq[0].nftset=""
for domain in $(cat "$LIST" | tr -d '\r'); do
    [ -z "$domain" ] && continue
    uci add_list dhcp.@dnsmasq[0].nftset="$domain/$FW_PATH"
    
    ips=$(nslookup "$domain" 1.1.1.1 2>/dev/null | grep 'Address' | grep -v '1.1.1.1' | awk '{print $NF}')
    for ip in $ips; do
        [ -n "$ip" ] && nft add element inet fw4 $SET_NAME { "$ip" } 2>/dev/null
    done
done

uci commit dhcp
/etc/init.d/dnsmasq restart