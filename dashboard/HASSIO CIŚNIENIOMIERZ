type: custom:flex-table-card
sort_by: ts-
entities:
  include:
    - sensor.omron_m4_history
columns:
  - name: 🕒<br>Data i Czas
    data: rows
    modify: |-
      (function(){
        let t = String(x.time);
        if (t.includes('-')) {
          let p = t.split(' ');
          let d = p[0].split('-');
          return d[2] + '.' + d[1] + ' ' + p[1].substring(0,5);
        }
        return t.replace('.2026', '');
      })()
  - name: 💢<br>PP
    data: rows
    modify: |-
      (function(){
        if (!x.pressure) return '---';
        var p = x.pressure.split('/');
        var s = parseInt(p[0]);
        var d = parseInt(p[1]);
        var pp = s - d;
        if (pp >= 60) return pp + ' 🔴';
        if (pp >= 50) return pp + ' 🟡';
        if (pp >= 40) return pp + ' 🟢';
        return pp + ' 💚';
      })()
    align: center
  - name: 🩺<br>Ciśnie.
    data: rows
    modify: x.pressure && x.pressure.replace(' mmHg','')
    align: center
  - name: 🚦<br>S0-3
    data: rows
    modify: |-
      (function(){
        if (!x.pressure) return '---';
        var p = x.pressure.split('/');
        var s = parseInt(p[0]); var d = parseInt(p[1]);
        if (s >= 180 || d >= 110) return '⛔ S3';
        if (s >= 160 || d >= 100) return '🔴 S2';
        if (s >= 140 || d >=  90) return '🟠 S1';
        if (s >= 130 || d >=  85) return '🟡 S0';
        if (s >= 120 || d >=  80) return '🔵 Pr';
        return '🟢 Pr';
      })()
    align: center
  - name: ❤️<br>Tęt
    data: rows
    modify: x.pulse && x.pulse.replace(' bpm','')
    align: center
  - name: 🧗<br>Str
    data: rows
    modify: |-
      (function(){
        try {
          const gHist = document.querySelector("home-assistant").hass.states['sensor.garmin_history'];
          const gRows = gHist.attributes.rows;
          const omronTime = new Date(x.ts * 1000).getTime();
          const getLsTs = (r) => new Date(r.ls.replace('T', ' ').split('.')[0]).getTime();
          const closest = gRows.reduce((prev, curr) => (Math.abs(getLsTs(curr) - omronTime) < Math.abs(getLsTs(prev) - omronTime) ? curr : prev));
          if (Math.abs(getLsTs(closest) - omronTime) > 14 * 3600000) return '---';
          return closest.stress || '---';
        } catch(e) { return '---'; }
      })()
    align: center
  - name: ⚡<br>BB
    data: rows
    modify: |-
      (function(){
        try {
          const gHist = document.querySelector("home-assistant").hass.states['sensor.garmin_history'];
          const gRows = gHist.attributes.rows;
          const omronTime = new Date(x.ts * 1000).getTime();
          const getLsTs = (r) => new Date(r.ls.replace('T', ' ').split('.')[0]).getTime();
          const closest = gRows.reduce((prev, curr) => (Math.abs(getLsTs(curr) - omronTime) < Math.abs(getLsTs(prev) - omronTime) ? curr : prev));
          if (Math.abs(getLsTs(closest) - omronTime) > 14 * 3600000) return '---';
          return closest.bb || '---';
        } catch(e) { return '---'; }
      })()
    align: center
  - name: 💤<br>RhR
    data: rows
    modify: |-
      (function(){
        try {
          const gHist = document.querySelector("home-assistant").hass.states['sensor.garmin_history'];
          const gRows = gHist.attributes.rows;
          const omronTime = new Date(x.ts * 1000).getTime();
          const getLsTs = (r) => new Date(r.ls.replace('T', ' ').split('.')[0]).getTime();
          const closest = gRows.reduce((prev, curr) => (Math.abs(getLsTs(curr) - omronTime) < Math.abs(getLsTs(prev) - omronTime) ? curr : prev));
          if (Math.abs(getLsTs(closest) - omronTime) > 14 * 3600000) return '---';
          return closest.rhr || '---';
        } catch(e) { return '---'; }
      })()
    align: center
  - name: 🛌<br>Sen
    data: rows
    modify: |-
      (function(){
        try {
          const gHist = document.querySelector("home-assistant").hass.states['sensor.garmin_history'];
          const gRows = gHist.attributes.rows;
          const omronTime = new Date(x.ts * 1000).getTime();
          const getLsTs = (r) => new Date(r.ls.replace('T', ' ').split('.')[0]).getTime();
          const closest = gRows.reduce((prev, curr) => (Math.abs(getLsTs(curr) - omronTime) < Math.abs(getLsTs(prev) - omronTime) ? curr : prev));
          if (Math.abs(getLsTs(closest) - omronTime) > 14 * 3600000) return '---';
          return (closest.ss && closest.ss != "0") ? closest.ss + '/' + closest.sh + 'h' : '---';
        } catch(e) { return '---'; }
      })()
    align: center
  - name: 🔄<br>Sync
    data: rows
    modify: |-
      (function(){
        try {
          const gHist = document.querySelector("home-assistant").hass.states['sensor.garmin_history'];
          const gRows = gHist.attributes.rows;
          const omronTime = new Date(x.ts * 1000).getTime();
          const getLsTs = (r) => new Date(r.ls.replace('T', ' ').split('.')[0]).getTime();
          const closest = gRows.reduce((prev, curr) => (Math.abs(getLsTs(curr) - omronTime) < Math.abs(getLsTs(prev) - omronTime) ? curr : prev));
          if (Math.abs(getLsTs(closest) - omronTime) > 14 * 3600000) return '---';
          const ls = String(closest.ls);
          const timePart = ls.includes('T') ? ls.split('T')[1] : ls.split(' ')[1];
          return timePart ? timePart.substring(0, 5) : '---';
        } catch(e) { return '---'; }
      })()
    align: center
  - name: ⚖️<br>Waga
    data: rows
    modify: |-
      (function(){
        try {
          const hist = document.querySelector("home-assistant").hass.states['sensor.xiaomi_s400_history'];
          const parsed = hist.attributes.rows.map(r => ({t: Number(r.ts), w: parseFloat(String(r.weight))}));
          const last30 = parsed.filter(r => (Date.now()/1000 - r.t) <= (30*24*3600));
          return last30.length === 0 ? '---' : (last30.reduce((s, r) => s + r.w, 0) / last30.length).toFixed(1);
        } catch(e){ return '---'; }
      })()
    align: center
  - name: 📊<br>Ktx
    data: rows
    modify: |-
      (function(){
        try {
          const hist = document.querySelector("home-assistant").hass.states['sensor.xiaomi_s400_history'];
          if (!hist || !hist.attributes || !hist.attributes.rows) return '';
          const sorted = hist.attributes.rows.map(r => ({t: Number(r.ts), w: parseFloat(String(r.weight))})).sort((a,b) => b.t - a.t);
          if (sorted.length < 2) return '';
          const diff = sorted[0].w - sorted[1].w;
          return diff > 0.3 ? '⚠️↑' : (diff < -0.3 ? '✅↓' : '➖');
        } catch(e){ return ''; }
      })()
    align: center
strict: true
card_mod:
  style: |
    ha-card {
      max-height: 333px;
      overflow-y: auto;
      font-size: 12px;
      user-select: text !important;
      -webkit-user-select: text !important;
    }
    ha-card table {
      width: 99% !important;
      border-collapse: collapse;
      table-layout: auto;
    }
    ha-card thead th {
      text-align: center;
      vertical-align: bottom;
      padding: 2px 2px !important;
      line-height: 1.1;
      font-weight: bold;
      position: sticky;
      top: 0;
      background: var(--card-background-color);
      z-index: 2;
    }
    ha-card td {
      padding: 1px 2px !important;
      white-space: nowrap !important;
    }
    ha-card td:first-child,
    ha-card th:first-child {
      width: 1px;
    }
